// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "experimental.theme_overrides": {
    "panel.focused_border": "#FFA500",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/opt/homebrew/bin/claude",
      },
    },
  },
  "disable_ai": true,
  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "zed",
  },
  "tab_size": 2,
  "hard_tabs": false,
  "auto_indent_on_paste": false,
  "ui_font_weight": 400,
  "buffer_font_features": { "calt": true, "liga": true },
  "buffer_font_weight": 400,
  "ui_font_family": ".ZedSans",
  "ui_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15,
  "terminal": {
    "font_weight": 400,
    "dock": "bottom",
    "toolbar": {
      "breadcrumbs": false,
    },
    "button": true,
    "cursor_shape": "block",
    "font_size": 14,
    "line_height": {
      "custom": 1.75,
    },
    "font_family": "JetBrainsMono Nerd Font",
    "max_scroll_history_lines": 1000,
  },
  "lsp_document_colors": "background",
  "calls": {
    "mute_on_join": true,
  },
  "buffer_line_height": {
    "custom": 1.75,
  },
  "collaboration_panel": {
    "button": false,
    "default_width": 320.0,
  },
  "preview_tabs": {
    "enable_preview_from_project_panel": false,
    "enable_preview_from_file_finder": true,
    "enabled": true,
  },
  "tabs": {
    "file_icons": false,
    "git_status": false,
  },
  "max_tabs": 3,
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show": false,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_user_menu": true,
    "show_sign_in": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_branch_icon": true,
  },
  "debugger": {
    "dock": "right",
    "button": true,
  },
  "search": {
    "button": true,
  },
  "bottom_dock_layout": "right_aligned",
  "use_system_window_tabs": true,
  "diagnostics": {
    "button": true,
  },
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": true,
  },
  "use_autoclose": true,
  "jsx_tag_auto_close": {
    "enabled": true,
  },
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "toolbar": {
    "quick_actions": true,
    "breadcrumbs": true,
  },
  "current_line_highlight": "all",
  "rounded_selection": true,
  "cursor_shape": "bar",
  "agent_buffer_font_size": 16.0,
  "agent_ui_font_size": 16.0,
  "agent": {
    "dock": "left",
    "use_modifier_to_send": true,
    "enable_feedback": false,
    "default_width": 640.0,
    "default_height": 320.0,
    "favorite_models": [],
    "model_parameters": [],
  },
  "notification_panel": {
    "button": false,
    "default_width": 320.0,
  },
  "outline_panel": {
    "dock": "right",
    "button": true,
    "default_width": 320.0,
  },
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Dark Official Icons)",
    "dark": "VSCode Icons for Zed (Dark Official Icons)",
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "bold_folder_labels": false,
    "indent_guides": {
      "show": "always",
    },
    "button": true,
    "default_width": 320.0,
    "dock": "right",
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Underground",
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "formatting.gofumpt": false,
        "ui.diagnostics.staticcheck": true,
        "ui.diagnostics.analyses": {
          "unusedparams": true,
          "shadow": true,
        },
      },
    },
  },
  "format_on_save": "on",
  "languages": {
    "Go": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "goimports",
          "arguments": [],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "Go Mod": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "SQL": {
      "formatter": {
        "external": {
          "command": "sql-formatter",
        },
      },
      "format_on_save": "on",
    },
  },
}
