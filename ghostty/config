# Theme
theme = nord
background = #282c35
background-opacity = 0.95
background-blur = 25

# Font
font-family = CommitMono
font-size = 14
font-thicken = true
font-thicken-strength = 0

# Cursor
cursor-color = #A3BE8C
mouse-hide-while-typing = true

# Padding (left, right, top, bottom → x/y in Ghostty)
window-padding-x = 4,0
window-padding-y = 2,0

# Window
macos-titlebar-style = hidden
window-save-state = always
maximize = true
confirm-close-surface = false
quick-terminal-position = center

# Keybinds (Ctrl+Enter / Shift+Enter CSI u sequences)
keybind = ctrl+enter=text:\x1b[13;5u
keybind = shift+enter=text:\x1b[13;2u

# Spacing
adjust-cell-height =  40%

# Other
copy-on-select = clipboard

